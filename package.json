{
  "name": "greedy",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up",
    "dev:build": "docker compose up --build",
    "down": "docker compose down",
    "logs": "docker compose logs -f",
    "build": "yarn workspace @greedy/shared build && yarn workspace @greedy/api build && yarn workspace @greedy/web build",
    "build:desktop": "yarn workspace @greedy/shared build && yarn workspace @greedy/api build && yarn workspace @greedy/web build && yarn workspace @greedy/desktop build && yarn workspace @greedy/desktop build:content",
    "desktop:dev": "yarn build:desktop && yarn workspace @greedy/desktop start",
    "desktop:dist": "yarn build:desktop && yarn workspace @greedy/desktop dist",
    "content:build": "yarn workspace @greedy/desktop build:content",
    "content:pack": "yarn workspace @greedy/desktop pack:content",
    "content:publish": "yarn workspace @greedy/desktop publish:content",
    "content:serve": "yarn workspace @greedy/desktop serve:content",
    "content:release": "yarn build && yarn workspace @greedy/desktop build:content && yarn workspace @greedy/desktop pack:content && yarn workspace @greedy/desktop publish:content",
    "gen:keys": "yarn workspace @greedy/desktop gen:keys",
    "db:generate": "yarn workspace @greedy/api db:generate",
    "db:migrate": "yarn workspace @greedy/api db:migrate",
    "db:push": "yarn workspace @greedy/api db:push",
    "db:studio": "yarn workspace @greedy/api db:studio",
    "typecheck": "yarn workspaces run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,yml,yaml}": "prettier --write"
  }
}
